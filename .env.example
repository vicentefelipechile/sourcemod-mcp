# =========================================================================================================
# SourceMod MCP — Environment Configuration
# =========================================================================================================
# Copy this file to .env and fill in values for your local setup.

# --- Local socket bridge (MCP <-> bridge plugin) ---
# TCP port the MCP listens on for the bridge plugin to connect to.
SM_MCP_SOCKET_HOST=127.0.0.1
SM_MCP_SOCKET_PORT=27100

# --- SourceMod / game server paths ---
# Root of the game server install (the folder containing the game dir, e.g. .../tf).
SM_GAME_ROOT=C:/servers/tf2/tf
# SourceMod scripting dir (where .sp sources live).
SM_SCRIPTING_DIR=C:/servers/tf2/tf/addons/sourcemod/scripting
# Compiled plugins dir (where .smx get deployed).
SM_PLUGINS_DIR=C:/servers/tf2/tf/addons/sourcemod/plugins
# Server config dir (cfg).
SM_CFG_DIR=C:/servers/tf2/tf/cfg

# --- spcomp compiler ---
# Path to the SourcePawn compiler binary (spcomp / spcomp64).
SM_SPCOMP_BIN=C:/servers/tf2/tf/addons/sourcemod/scripting/spcomp64.exe

# --- Scratch scripting (ephemeral one-off scripts) ---
# Isolated dir for ephemeral scratch scripts. Wiped on startup and shutdown.
SM_SCRATCH_DIR=./scratch

# --- RCON fallback ---
SM_RCON_HOST=127.0.0.1
SM_RCON_PORT=27015
SM_RCON_PASSWORD=changeme
